<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
	<system.serviceModel>
		<services>
			<service name="Server.CupidService">
				<endpoint address="net.tcp://localhost:8080/CupidService"
						  binding="netTcpBinding"
						  contract="Common.ICupidService"
						  bindingConfiguration="NetTcpBindingConfig" />
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:8080"/>
					</baseAddresses>
				</host>
			</service>
		</services>
		<bindings>
			<netTcpBinding>
				<binding name="NetTcpBindingConfig" portSharingEnabled="false" />
			</netTcpBinding>
		</bindings>
	</system.serviceModel>
</configuration>